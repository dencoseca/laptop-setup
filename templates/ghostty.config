# Ghostty configuration for macOS.
# Installed at ~/Library/Application Support/com.mitchellh.ghostty/config.
# Reload with Cmd+Shift+,; titlebar changes require a new window.

# Typography. JetBrains Mono and symbol glyph fallbacks ship with Ghostty.
font-family = JetBrains Mono
font-size = 13
font-thicken = true
font-thicken-strength = 24
adjust-cell-height = 4%

# Near-black canvas with cool lavender accents.
background = #000000
foreground = #E7E5EB
background-opacity = 1.0
cursor-color = #B7AEFF
cursor-text = #000000
cursor-style = bar
cursor-style-blink = true
selection-background = #2B2933
selection-foreground = #FFFFFF

# Dark, bright ANSI palette.
palette = 0=#000000
palette = 1=#FF6B6B
palette = 2=#A7E46B
palette = 3=#F6C85F
palette = 4=#7AA2F7
palette = 5=#D89CFF
palette = 6=#55DDE0
palette = 7=#E7E5EB
palette = 8=#69676F
palette = 9=#FF8787
palette = 10=#B9F27C
palette = 11=#FFD975
palette = 12=#8FB3FF
palette = 13=#FF8AD8
palette = 14=#72E6E6
palette = 15=#FFFFFF

# Spacious content with a narrower default window.
window-padding-x = 22
window-padding-y = 16
window-padding-balance = true
window-padding-color = background
window-width = 120

# Integrated tab strip and native macOS traffic lights.
macos-titlebar-style = tabs
macos-window-buttons = visible
window-theme = dark
window-title-font-family = JetBrains Mono

# Subtle split borders.
split-divider-color = #242428
unfocused-split-opacity = 0.92

# Keep new tabs and splits in the current directory.
shell-integration = detect
window-inherit-working-directory = true
tab-inherit-working-directory = true
split-inherit-working-directory = true

# Quality-of-life defaults.
mouse-hide-while-typing = true
cursor-click-to-move = true
scrollback-limit = 104857600
