export ZSH="$HOME/.oh-my-zsh"
zstyle ':omz:update' mode disabled
plugins=(git)
source "$ZSH/oh-my-zsh.sh"

#---------#
#  TOOLS
#---------#

# starship
eval "$(starship init zsh)"

# add new line for warp
PROMPT="${PROMPT}"$'\n'

# docker with colima
