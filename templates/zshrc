      h=int(($1%86400)/3600);
      m=int(($1%3600)/60);
      s=$1%60;
      result="";
      if(d>0) result = result d (d==1 ? " day" : " days");
      if(h>0) result = (length(result)>0 ? result ", " : result) h (h==1 ? " hr" : " hrs");
